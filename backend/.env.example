# ============================================================
# Rishikesh Smart Travel Guide — Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# PostgreSQL
DATABASE_URL=postgresql://rtg_user:rtg_password@localhost:5432/rishikesh_travel?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Weather API (Weatherstack)
# Sign up at https://weatherstack.com — free plan gives 250 calls/month
WEATHERSTACK_API_KEY=your_weatherstack_api_key_here
WEATHERSTACK_API_BASE_URL=http://api.weatherstack.com/current
WEATHERSTACK_QUERY=Rishikesh,India
WEATHER_CACHE_TTL_SECONDS=900

# Google Maps (optional — Reach module falls back to static data if absent)
GOOGLE_MAPS_API_KEY=

# OpenRouteService (optional free alternative to Google Maps)
# Sign up at https://openrouteservice.org
ORS_API_KEY=

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# JWT (auth-ready — not enforced yet, reserved for future user features)
JWT_SECRET=change_this_to_a_strong_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info
